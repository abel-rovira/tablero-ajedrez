<Window x:Class="TableroAjedrez.VentanaPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajedrez"
        Height="820"
        Width="820"
        MinHeight="760"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#423936">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Border BorderThickness="0"
                    BorderBrush="{StaticResource BoardOutline}"
                    Background="{StaticResource BoardOutline}"
                    Padding="0">
                <UniformGrid x:Name="CuadriculaTablero"
                             Width="672"
                             Height="672"
                             Rows="8"
                             Columns="8" />
            </Border>

            <TextBlock x:Name="TextoEstado"
                       HorizontalAlignment="Center"
                       Margin="0 14 0 0"
                       Foreground="#FAE8C8"
                       FontSize="17"
                       FontWeight="SemiBold" />
        </StackPanel>

        <Grid x:Name="PanelFinPartida"
              Visibility="Collapsed"
              Background="#B0000000">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="330"
                    Padding="28"
                    Background="#423936"
                    BorderBrush="#FAE8C8"
                    BorderThickness="2">
                <StackPanel>
                    <TextBlock x:Name="TextoFinPartida"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="#FAE8C8"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0 0 0 22" />
                    <Button Content="Nueva partida"
                            Click="BotonNuevaPartida_Click"
                            FontSize="18"
                            Padding="18 10"
                            Margin="0 0 0 12" />
                    <Button Content="Salir"
                            Click="BotonSalir_Click"
                            FontSize="18"
                            Padding="18 10" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
